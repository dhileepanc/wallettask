<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FE"
    android:padding="24dp">

    <RelativeLayout
        android:id="@+id/header_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="8dp"
        app:layout_constraintTop_toTopOf="parent">
              <TextView
            android:id="@+id/add_card_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="ADD CARD"
            android:textColor="#2196F3"
            android:textSize="14sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Top Saved Card Strip -->
    <androidx.cardview.widget.CardView
        android:id="@+id/saved_card_top"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/header_bar">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="20dp"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_mastercard"
                android:scaleType="centerInside" />
            <TextView
                android:id="@+id/saved_card_number_top"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text=""
                android:textColor="#333333"
                android:textSize="14sp"
                android:letterSpacing="0.05" />
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_checked" />
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/credit_card_view"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/saved_card_top">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/gradient_card_blue"
            android:padding="20dp">
            
            <ImageView
                android:id="@+id/card_type_logo"
                android:layout_width="60dp"
                android:layout_height="30dp"
                android:src="@drawable/ic_visa_white"
                android:scaleType="centerInside" />

            <TextView
                android:id="@+id/expiry_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="EXPIRY DATE"
                android:textColor="#CCFFFFFF"
                android:textSize="9sp"
                android:textStyle="bold" />
            
            <EditText
                android:id="@+id/card_expiry_edit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_below="@id/expiry_label"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_card_field"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:hint="22 / 24"
                android:textColorHint="#99FFFFFF"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/number_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_above="@id/card_number_edit"
                android:layout_marginBottom="4dp"
                android:text="CARD NUMBER"
                android:textColor="#CCFFFFFF"
                android:textSize="9sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/card_number_edit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:background="@drawable/bg_card_field"
                android:padding="10dp"
                android:hint="3344 - 9988 - 4567 - 2323"
                android:textColorHint="#99FFFFFF"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:letterSpacing="0.05"
                android:inputType="phone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:orientation="horizontal">
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CARD HOLDER"
                        android:textColor="#CCFFFFFF"
                        android:textSize="9sp"
                        android:textStyle="bold" />
                    <EditText
                        android:id="@+id/card_holder_edit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_card_field"
                        android:padding="8dp"
                        android:hint="Rohit Sharma"
                        android:textColorHint="#99FFFFFF"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CVV"
                        android:textColor="#CCFFFFFF"
                        android:textSize="9sp"
                        android:textStyle="bold" />
                    <EditText
                        android:id="@+id/card_cvv_edit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:background="@drawable/bg_card_field"
                        android:padding="8dp"
                        android:hint="* * *"
                        android:textColorHint="#99FFFFFF"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:gravity="center"
                        android:inputType="numberPassword" />
                </LinearLayout>
            </LinearLayout>
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <!-- Bottom Saved Card Strip -->
    <androidx.cardview.widget.CardView
        android:id="@+id/saved_card_bottom"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/credit_card_view">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp">
            <ImageView
                android:layout_width="40dp"
                android:layout_height="25dp"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_mastercard"
                android:scaleType="centerInside" />
            <TextView
                android:id="@+id/saved_card_number_bottom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text=""
                android:textColor="#333333"
                android:textSize="14sp"
                android:letterSpacing="0.05" />
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_unchecked" />
        </RelativeLayout>
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:id="@+id/scan_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/saved_card_bottom">
        <ImageView
            android:id="@+id/scan_qr_icon"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:src="@drawable/ic_qr_scan" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Scan Card"
            android:textColor="#2196F3"
            android:textSize="14sp" />
    </LinearLayout>

    <EditText
        android:id="@+id/transfer_amount_edit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Enter amount"
        android:inputType="numberDecimal"
        android:paddingVertical="12dp"
        android:background="#00000000"
        android:textColor="#2196F3"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/scan_container" />

    <View
        android:id="@+id/amount_underline"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2196F3"
        app:layout_constraintTop_toBottomOf="@id/transfer_amount_edit" />

    <Button
        android:id="@+id/final_add_card_button"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="24dp"
        android:backgroundTint="#2196F3"
        android:text="ADD CARD"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:cornerRadius="28dp"
        app:layout_constraintTop_toBottomOf="@id/amount_underline" />

</androidx.constraintlayout.widget.ConstraintLayout>
