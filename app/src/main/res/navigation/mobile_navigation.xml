<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@id/navigation_home">

    <fragment
        android:id="@+id/navigation_home"
        android:name="com.app.wallettask.ui.wallet.WalletFragment"
        android:label="Home"
        tools:layout="@layout/fragment_wallet" />

    <fragment
        android:id="@+id/navigation_cards"
        android:name="com.app.wallettask.ui.cards.CardsFragment"
        android:label="Cards"
        tools:layout="@layout/fragment_cards" />

    <fragment
        android:id="@+id/navigation_profile"
        android:name="com.app.wallettask.ui.profile.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile" />

    <fragment
        android:id="@+id/navigation_history"
        android:name="com.app.wallettask.ui.history.HistoryFragment"
        android:label="History"
        tools:layout="@layout/fragment_history" />
</navigation>
